modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"
packages = ["vim-full"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 34097
externalPort = 3003

[[ports]]
localPort = 35071
externalPort = 3000

[[ports]]
localPort = 38983
externalPort = 3001

[[ports]]
localPort = 41153
externalPort = 3002
